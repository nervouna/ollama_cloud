# Copy this file to .env and fill in your values.
# The .env file is listed in .gitignore and will NOT be committed.

# Required – base URL of your Ollama-compatible cloud endpoint.
# Example: https://my-ollama-host.example.com
OLLAMA_BASE_URL=https://your-ollama-cloud-endpoint

# Required – bearer token / API key issued by your provider.
OLLAMA_API_KEY=your-api-key-here

# Optional – default model to use for all demo calls.
# Falls back to qwen3.5:397b-cloud when not set.
OLLAMA_MODEL=qwen3.5:397b-cloud

# Optional – local image file used for the image analysis demo.
# Relative paths are resolved from the example/ directory.
OLLAMA_IMAGE_PATH=assets/demo-image.jpg

# Optional – local video file used for the video analysis demo.
# The example samples keyframes with ffmpeg, then sends those frames to the model.
OLLAMA_VIDEO_PATH=assets/demo-video.mp4
